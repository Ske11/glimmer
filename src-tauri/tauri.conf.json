{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Glimmer",
  "version": "0.1.0",
  "identifier": "io.ske11.glimmer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "浮光 Glimmer"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "Utility",
    "copyright": "2026 Glimmer",
    "shortDescription": "macOS 桌面浮动组件",
    "longDescription": "浮光 — 一款 macOS 桌面浮动组件应用，提供时钟、待办、心语、倒计时、便签五种组件，搭配八种粒子场景主题，玻璃质感沉浸体验。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "../src-tauri/Info.plist"
    }
  }
}
